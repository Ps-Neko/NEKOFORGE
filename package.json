{
  "name": "nekoforge",
  "version": "0.5.0-alpha.5",
  "description": "NEKOFORGE — source-aware local AI development harness: turns existing codebases into reusable context and task packets, and gates AI changes behind a tamper-evident verdict before explicit apply.",
  "private": true,
  "type": "module",
  "bin": {
    "nekoforge": "./dist/src/cli/index.js",
    "harness": "./dist/src/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/cli/index.js",
    "dev": "tsx src/cli/index.ts",
    "test": "node --test --import tsx tests/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src tests",
    "depcheck": "depcruise --config depcruise.config.cjs src",
    "benchmark": "tsx src/cli/index.ts benchmark",
    "verify": "npm run typecheck && npm run lint && npm run depcheck && npm test",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "dependency-cruiser": "^16.10.0",
    "eslint": "^9.17.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.59.3"
  },
  "engines": {
    "node": ">=20"
  }
}
